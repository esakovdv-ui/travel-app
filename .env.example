# ─────────────────────────────────────────────
# Переменные окружения — заполнить перед деплоем
# Этот файл — шаблон. Реальные значения хранить в .env.local (не коммитить)
# ─────────────────────────────────────────────

# ── База данных ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mytrip

# ── Level Travel API ──────────────────────────
LEVEL_TRAVEL_API_KEY=your_api_key_here
NEXT_PUBLIC_WL_BASE_URL=https://russia.mosgortur.ru

# ── Сессии ───────────────────────────────────
JWT_SECRET=replace_with_long_random_secret_min_32_chars
COOKIE_SECURE=true

# ── Email-уведомления (истории путешествий) ───
# Используется для отправки письма Анне Бочковой при новой истории
# Настроить SMTP или сервис (Nodemailer / Resend / SendGrid)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@mosgortur.ru
SMTP_PASS=your_smtp_password

# Email модератора историй (Анна Бочкова)
STORIES_NOTIFY_EMAIL=a.bochkova@mosgortur.ru

# Тема письма будет: "Новая история путешествия — [Объект] — [Дата]"
